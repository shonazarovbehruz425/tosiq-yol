## Server port (Render sets this automatically in production)
PORT=3000

## Telegram Bot token from @BotFather (required for production auth)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

## Public URL of the deployed Mini App (used by the bot's "Play" button & menu)
## e.g. https://tosiq-yol.onrender.com
WEBAPP_URL=

## Admin panel password — change this to a strong secret!
ADMIN_TOKEN=change_me_to_a_strong_password

## Secret used to sign admin session cookies.
## If omitted, a random one is generated on each restart (sessions reset on redeploy).
## Set a fixed strong value in production to keep sessions valid across restarts.
ADMIN_SESSION_SECRET=change_me_to_a_long_random_string

## Directory for persistent data (db.json). Optional.
## If unset, the server uses a writable local/temp dir (ephemeral on Render).
## For free permanent storage, use DB_CHANNEL_ID below instead.
DATA_DIR=

## ===== Free permanent database via a Telegram channel =====
## Create a private channel, add your bot as ADMIN (with post + pin rights),
## then put the channel id here (e.g. -1001234567890).
## The bot stores db.json in the channel and restores it on every restart,
## so data survives Render redeploys for free (no paid disk needed).
DB_CHANNEL_ID=
