# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
dist-ssr/
build/
# Keep DotBox pre-built files (no build step on Render for this sub-app)
!DotBox/dist/
!DotBox/dist/**

# Environment & secrets
.env
.env.*
!.env.example
**/.env

# Runtime data (contains user data — do not commit)
server/db.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.sw?

# Misc
*.local
